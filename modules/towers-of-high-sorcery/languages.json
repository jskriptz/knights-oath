      "name": "Infernal",
      "script": "Infernal",
      "speakers": "Devils, fiends, Takhisis cultists",
      "desc": "The language of the Nine Hells. Contracts written in Infernal are said to be binding beyond death.",
      "phrases": {
        "Takhisis-eth-dominar": "Takhisis dominates all",
        "Nuitari obscurath": "Nuitari darkens (black moon blessing)",
        "Chemosh-mortis-rex": "Chemosh, Lord of the Dead",
        "Sargonnas-eth-vengar": "Sargonnas demands vengeance",
        "Morgion-pestileth": "Morgion's plague spreads",
        "Hiddukel-contractum": "Hiddukel's bargain (binding deal)",
        "Zeboim-tempestath": "Zeboim's storm rages",
        "Darkness-eternal-binds": "The pact is sealed",
        "Five-heads-rise": "The Dark Queen awakens",
        "Dragon-queen-commands": "Takhisis has spoken",
        "Soul-forfeit": "Your soul is claimed",
        "Temple-of-Neraka": "The dark heart of the empire"
      }
    },
    "abyssal": {
      "name": "Abyssal",
      "script": "Infernal",
      "speakers": "Demons, chaotic fiends",
      "desc": "A maddening tongue that shifts meaning with every utterance. Few mortals can speak it without losing something of themselves."
    },
    "primordial": {
      "name": "Primordial",
      "script": "Dwarvish",
      "speakers": "Elementals",
      "desc": "The root language of the elemental planes. Dialects include Aquan, Auran, Ignan, and Terran."
    },
    "sylvan": {
      "name": "Sylvan",
      "script": "Elvish",
      "speakers": "Fey creatures, dryads, satyrs",
