{
  "languages": {
    "common": {
      "name": "Common",
      "script": "Common",
      "speakers": "Humans, most species",
      "desc": "The trade tongue of Ansalon, understood in every civilised land."
    },
    "solamnic": {
      "name": "Solamnic",
      "script": "Common",
      "speakers": "Knights of Solamnia, Solamnic nobility",
      "desc": "The formal language of the Solamnic knighthood, used in the Oath and Measure. Archaic phrases mark official decrees and ancient texts.",
      "phrases": {
        "Est Sularus oth Mithas": "My honour is my life",
        "Solanthus valar": "In Solamnia's name",
        "Kiri oth Paladine": "By Paladine's light",
        "Uth matar, uth khas": "To death, to glory",
        "Vinas eth Solamnus": "Vinas founded Solamnia (invocation of the founder)",
        "Sturm eth valoris": "Stand with valour",
        "Khas oth Mesura": "Honour the Measure",
        "Est kiri, est sularus": "With light, with honour",
        "Oth matar venari": "Until death takes me",
        "Paladine valoreth": "Paladine watch over (blessing)"
      }
    },
    "elvish": {
      "name": "Elvish",
      "script": "Elvish",
      "speakers": "Elves (Silvanesti, Qualinesti, Kagonesti)",
      "desc": "The melodic tongue of the elves. Silvanesti speak a more formal dialect; Qualinesti is slightly more accessible to outsiders.",
      "phrases": {
        "Qualinost anarani": "The sun rises over Qualinost (greeting)",
        "Silvanesti eth'alar": "Silvanesti endures (formal blessing)",
        "Aelas'quinar": "Starlight guide you (farewell)",
        "Thalion eth sarana": "The forest remembers",
        "Kith-Kanan valoreth": "Kith-Kanan's blessing upon you",
        "Anari solan'thas": "Dawn comes after darkness",
        "Quinar eth'alas": "The stars weep (lament)",
        "Silvanos eth'alar turath": "By Silvanos, founder of our people",
        "Tanis'ara melath": "Half-blood of two worlds (term for half-elves)",
        "Karas'thel anarani": "The dragon shadow falls (warning)",
        "E'li shonath": "In E'li's light (Qualinesti blessing)",
        "Sar-thelas kagonar": "Wild ones of the forest (Kagonesti)"
      }
    },
    "dwarvish": {
      "name": "Dwarvish",
      "script": "Dwarvish",
      "speakers": "Dwarves (Hylar, Neidar, Theiwar, Daergar, Klar, Aghar)",
      "desc": "A rumbling, consonant-heavy language carved into stone as often as spoken. Clan dialects vary but are mutually intelligible.",
      "phrases": {
        "Thorbardin khaz": "Thorbardin stands (affirmation)",
        "Reorx dunnarak": "Reorx forged it true (praise for craftsmanship)",
        "Khaz-dum baraz": "Stone and steel endure",
        "Thane khazak": "By the Thane's word",
        "Groth Neidar": "Hill dwarf (term, sometimes derogatory)",
        "Hylar valorakh": "High dwarf honour",
        "Kazak-thul murad": "The mountain holds secrets",
        "Daergar eth'khor": "Dark dwarf (warning)",
        "Aghar skrag": "Gully dwarf filth (insult)",
        "Khaz-modan reorakh": "May Reorx strengthen your arm",
        "Dum-baraz thul": "The deep roads call",
        "Derkin valorakh eth": "Derkin's courage lives on"
      }
    },
    "gnomish": {
      "name": "Gnomish",
      "script": "Dwarvish",
      "speakers": "Gnomes of Mount Nevermind",
      "desc": "An incredibly fast, technical language. Gnomes speak in run-on sentences that can last minutes. Names are generations-long stories.",
      "phrases": {
        "Nevermindtechnologicalinnovation": "Hello (abbreviated greeting)",
        "Gearsprocket-steamwheel-pressurevalve": "The machine works!",
        "Explosionunintendedbutdataacquired": "A successful experiment",
        "Catapult-counterweight-trajectory-miscalculation": "Something went wrong",
        "Lifequest-assignment-pending": "What is your purpose?",
        "Gnomeflingermark-seven-improved": "Watch this!",
        "Committee-approval-subcommittee-review-pending": "It's complicated",
        "Mount-Nevermind-engineering-guild-certified": "This is quality work",
        "Steampower-cogwheel-rotation-optimal": "Everything is fine",
        "Tinkergnome-ancestral-innovation-continues": "I honour my ancestors"
      }
    },
    "draconic": {
      "name": "Draconic",
      "script": "Draconic",
      "speakers": "Dragons, dragonborn, Dragon Highlords",
      "desc": "The ancient tongue of dragons — harsh, sibilant, and powerful. Dragon Army commanders use it for orders they wish to keep secret.",
      "phrases": {
        "Ssissrath vex": "Kneel before me",
        "Thaxiss kazarath": "By Takhisis's will",
        "Draak-khan vorthiss": "Dragon Highlord commands",
        "Ssareth vulkaan": "Fire consumes all",
        "Korthax ssilith": "Death from above",
        "Verminaard kazak": "Lord Verminaard's word",
        "Ssilith-naar vex": "Submit or burn",
        "Khisanth voreth": "The black wing descends",
        "Pyross eth'naar": "Flame Lord's fury",
        "Takhisis rex valoreth": "The Dark Queen rises",
        "Draak-naar solakh": "Dragons rule the sky",
        "Sivak kazarath": "Sivak draconian, at your command",
        "Kapak ssilith": "Kapak strikes (assassination order)",
        "Baaz-thral vex": "Baaz troops, advance"
      }
    },
    "goblin": {
      "name": "Goblin",
      "script": "Dwarvish",
      "speakers": "Goblins, hobgoblins, bugbears",
      "desc": "A guttural language with many words for ambush, cowardice, and cruelty. The Dragon Armies use goblin troops as fodder.",
      "phrases": {
        "Grish'nak vult": "Kill them all",
        "Skrag-naar": "Worthless scum (insult)",
        "Hob'grak kazul": "Hobgoblin captain says",
        "Bug-thrak grish": "Bugbear smash!",
        "Draak-naar grik": "Dragon Army pays well",
        "Grik-skar groth": "Ambush ready",
        "Skrag vult naar": "Run away! (retreat)",
        "Thrak-nak grik": "Take their things",
        "Gob-skar eth": "Goblin knows",
        "Hob-thrak kazul": "The big ones command",
        "Grish eth skar": "Blood for the taking",
        "Nak-nak groth": "Night raid begins"
      }
    },
    "giant": {
      "name": "Giant",
      "script": "Dwarvish",
      "speakers": "Giants, ogres, some trolls",
      "desc": "A booming language suited to creatures of great size. Ogre dialects are cruder but comprehensible.",
      "phrases": {
        "THOG SMASH": "I will destroy you (ogre)",
        "Blode-khan commands": "The ogre chieftain orders",
        "Kern-thog strong": "Kern (Eastern ogre region) is mighty",
        "Small-meat runs": "The humans flee",
        "Ogre-thane speaks": "The ogre lord has spoken",
        "Mountain-blood flows": "We are of the mountains",
        "Troll-kin hungers": "The trolls need feeding",
        "Irda-betrayers": "The cursed beautiful ones (Irda)",
        "Stone-fist crushes": "Victory is certain",
        "Draak-serve good": "Serving dragons is profitable",
        "Old-kingdom remembers": "We remember when ogres ruled",
        "CRUSH BONES": "Attack! (battle cry)"
      }
    },
    "orc": {
      "name": "Orc",
      "script": "Dwarvish",
      "speakers": "Orcs, half-orcs",
      "desc": "A harsh, guttural language focused on warfare, raiding, and survival."
    },
    "halfling": {
      "name": "Halfling",
      "script": "Common",
      "speakers": "Halflings, kender (loosely)",
      "desc": "A warm, homey language. Kender speak a rapid, excitable dialect that borrows freely from every tongue they encounter."
    },
    "celestial": {
      "name": "Celestial",
      "script": "Celestial",
      "speakers": "Angels, divine servants, clerics (rare)",
      "desc": "The language of the gods' messengers. On Krynn, it has not been heard in three hundred years — until now.",
      "phrases": {
        "Paladine eth'solarus": "Paladine, Lord of Light",
        "Mishakal eth'sanar": "Mishakal the Healer blesses you",
        "Kiri-Jolith valoreth": "Kiri-Jolith grants courage",
        "Majere eth'silentum": "Majere speaks in stillness",
        "Branchala eth'cantus": "Branchala's song fills the air",
        "Habbakuk eth'maris": "Habbakuk rules the waters",
        "Solinari luminar": "Solinari shines (white moon blessing)",
        "Divinius returneth": "The gods have returned",
        "Sanctus benedictum": "Holy blessing upon you",
        "Lux aeterna": "Eternal light",
        "Nox terminat": "Darkness ends",
        "Animae salvar": "Soul is saved"
      }
    },
