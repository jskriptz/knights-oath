      "name": "Ergot",
      "script": "Common",
      "speakers": "Ergothians, sailors",
      "desc": "The language of Ergoth, once a great empire. Now a merchant tongue with many nautical terms."
    },
    "kenderspeak": {
      "name": "Kenderspeak",
      "script": "Common",
      "speakers": "Kender",
      "desc": "Not technically a language, but kender speak so rapidly and tangentially that outsiders often can't follow. Includes many 'borrowed' words.",
      "phrases": {
        "Oh that's interesting have you seen this before it reminds me of": "(greeting, sort of)",
        "I found this it must have fallen into my pouch somehow": "I didn't steal it",
        "Tasslehoff would have loved this": "This is exciting (reference to famous kender)",
        "Uncle Trapspringer always said": "Let me tell you a story",
        "Is that a DRAGON oh wow it's beautiful can I touch it": "Dragon sighting",
        "The map says go this way but this way looks more fun": "I'm getting us lost",
        "Afflicted": "A kender who has learned fear (grave insult)",
        "Handler-what a useful thing": "Nice weapon/tool (admiring)",
        "Borrowed-for-safekeeping": "Definitely not stealing",
        "Kendermore-born and wandered": "Proper kender introduction",
        "Ooh shiny": "(universal kender exclamation)"
